# 复制本文件为 .env（同目录），填入真实值。
# 推荐用 ./setup.sh 自动生成 .env，会引导填写并自动生成 secrets。
#
# ============================================
# 必填项（部署前你必须自己准备好）
# ============================================

# 部署使用的域名。必须满足两点：
#   1) 已在 Cloudflare 上托管（NS 指向 Cloudflare）
#   2) 有 A 记录指向本机公网 IP
# 例：worker.example.com
DOMAIN=

# Let's Encrypt 注册邮箱，证书续期通知会发到这里
ACME_EMAIL=

# Cloudflare API Token，权限要求：Zone → DNS → Edit（最好限定到 DOMAIN 所在的 zone）
# 创建位置：https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# ============================================
# 自动生成项（首次部署 setup.sh 会随机生成；之后不要随便改）
# ============================================

# Postgres 密码。注意：./data/postgres 一旦初始化就和这个值绑定了，
# 后期改这个值会导致 n8n 连不上库，必须连同 ./data/postgres 一起重置才行
POSTGRES_PASSWORD=

# n8n 主进程 ↔ task-runner 之间的鉴权 token，两边必须一致
N8N_RUNNERS_AUTH_TOKEN=
